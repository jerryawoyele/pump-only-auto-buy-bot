# Required match targets. Comma-separated; accepts handles, @handles, or full X/Twitter URLs.
TARGET_X_HANDLES=somehandle,anotherhandle,https://x.com/thirdhandle

# Trading safety. Keep false until you are ready for real on-chain buys.
AUTO_BUY_ENABLED=false
DRY_RUN=true

# Logging. normal logs matched tokens and active trades; test also logs every reject reason.
LOG_MODE=normal

# Wallet/RPC settings required only when DRY_RUN=false.
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
# Optional. Defaults to RPC_ENDPOINT with http(s) rewritten to ws(s).
RPC_WSS_ENDPOINT=wss://api.mainnet-beta.solana.com
PRIVATE_KEY_BASE58=

# Buy settings. BUY_AMOUNT_SOL is denominated in SOL.
BUY_AMOUNT_SOL=0.01
BUY_SLIPPAGE_PERCENT=10
SELL_SLIPPAGE_PERCENT=10
PRIORITY_FEE_SOL=0.00001
COMPUTE_UNIT_LIMIT=140000
# Optional override. If unset, the bot derives CU price from PRIORITY_FEE_SOL / COMPUTE_UNIT_LIMIT.
COMPUTE_UNIT_PRICE_MICRO_LAMPORTS=
MIN_BALANCE_SOL=0.02

# Take profit. 2 means sell when the current Pump sell quote is >= 2x initial buy spend.
TAKE_PROFIT_ENABLED=true
TAKE_PROFIT_MULTIPLIER=2
TAKE_PROFIT_POLL_INTERVAL_MS=1000
TAKE_PROFIT_MAX_DURATION_MS=900000
FLAT_EXIT_ENABLED=true
FLAT_EXIT_DELAY_MS=30000
FLAT_EXIT_MAX_GAIN_PERCENT=0
PUMP_STATE_CACHE_MS=30000

# Event filtering.
STALE_EVENT_MS=0
METADATA_TIMEOUT_MS=5000
TRANSACTION_FETCH_RETRIES=20
TRANSACTION_FETCH_RETRY_MS=300
BACKFILL_ENABLED=true
BACKFILL_MAX_SIGNATURES=50000
LISTENER_STATE_PATH=.state/pump-listener.json
# Fly.io uses /data/pump-listener.json via fly.toml with a mounted volume.
RECONNECT_BASE_MS=500
RECONNECT_MAX_MS=10000
WSS_PING_INTERVAL_MS=15000
WSS_IDLE_TIMEOUT_MS=45000
